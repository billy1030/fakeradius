# Binaries
bin/
*.exe
*.exe*.dll
*.so
*.dylib
# Allow pre-built distributable binaries in dist/
!dist/**/*.exe

# Logs
*.log
dist/server.log

# AI/Metadata (untracked per user request)
.claude/
.review/
.deepseek/
.planning/
scratch/

# Markdown (ignoring debug files except README/DEBUG)
*.md
!README.md
!debug*.md

# OS-specific
.DS_Store
Thumbs.db

# Go
vendor/

# Certificates and Keys
*.pem
*.p7b
*.pfx
*.csr
*.srl
*.key
